#!/bin/bash

echo ""
echo "🔍 Gitleaks: Scanning repo before push to GitHub..."

gitleaks detect --redact

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ SECRET DETECTED — Push has been BLOCKED."
    echo "   Remove the secret from history and rotate it immediately."
    echo ""
    exit 1
fi

echo "✅ Clean — pushing to GitHub."
echo ""

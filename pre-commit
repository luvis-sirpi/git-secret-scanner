#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

echo ""
echo -e "${BOLD}🔍 Gitleaks: Scanning staged files for secrets...${RESET}"
echo ""

STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}✅ No staged files to scan.${RESET}"
    exit 0
fi

TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

for FILE in $STAGED_FILES; do
    if git show ":$FILE" > /dev/null 2>&1; then
        mkdir -p "$TMPDIR/$(dirname $FILE)"
        git show ":$FILE" > "$TMPDIR/$FILE"
    fi
done

REPORT="$TMPDIR/report.json"

gitleaks detect \
    --source="$TMPDIR" \
    --config="$HOME/.gitleaks.toml" \
    --redact \
    --no-git \
    --report-format json \
    --report-path "$REPORT" > /dev/null 2>&1

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ] && [ -f "$REPORT" ]; then
    echo -e "${RED}${BOLD}Secrets found:${RESET}"
    echo ""

    # Parse JSON: show File (stripped of tmp prefix) and RuleID per finding
    python3 -c "
import json, sys

with open('$REPORT') as f:
    findings = json.load(f)

seen = set()
for item in findings:
    file = item.get('File', '').replace('$TMPDIR/', '')
    rule = item.get('RuleID', '')
    line = item.get('StartLine', '')
    key = f'{file}:{rule}:{line}'
    if key not in seen:
        seen.add(key)
        print(f'  \033[1;31m✗\033[0m  {file}  →  line {line}  →  {rule}')
"

    echo ""
    echo -e "${RED}${BOLD}╔══════════════════════════════════════════════╗${RESET}"
    echo -e "${RED}${BOLD}║   ❌  SECRET DETECTED — COMMIT BLOCKED       ║${RESET}"
    echo -e "${RED}${BOLD}╚══════════════════════════════════════════════╝${RESET}"
    echo ""
    echo -e "${YELLOW}  Fix:${RESET}  Remove the secret from the file(s) above."
    echo -e "${YELLOW}  Then:${RESET} git add <file> && git commit again."
    echo ""
    exit 1
fi

echo -e "${GREEN}${BOLD}✅ Clean — no secrets found. Proceeding with commit.${RESET}"
echo ""

#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

echo ""
echo -e "${BOLD}🔍 Gitleaks: Scanning staged files for secrets...${RESET}"
echo ""

STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}✅ No staged files to scan.${RESET}"
  exit 0
fi

gitleaks protect \
  --staged \
  --config="$HOME/.gitleaks.toml" \
  --redact \
  --verbose

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo -e "${RED}${BOLD}╔══════════════════════════════════════════════╗${RESET}"
  echo -e "${RED}${BOLD}║   ❌  SECRET DETECTED — COMMIT BLOCKED       ║${RESET}"
  echo -e "${RED}${BOLD}╚══════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "${YELLOW}  Fix:${RESET}  Remove the secret from the file(s) above."
  echo -e "${YELLOW}  Then:${RESET} git add <file> && git commit again."
  echo ""
  exit 1
fi

echo -e "${GREEN}${BOLD}✅ Clean — no secrets found. Proceeding with commit.${RESET}"
echo ""
